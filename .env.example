NODE_ENV=development
API_PORT=4000
WEB_PORT=5173
DATABASE_URL=postgresql://flowmind:flowmind@localhost:5432/flowmind
REDIS_URL=redis://localhost:6379
MCP_CREDENTIAL_ENCRYPTION_KEY=replace-with-a-long-random-secret
DATA_SOURCE_ENCRYPTION_KEY=replace-with-a-different-long-random-secret
MCP_CONNECT_TIMEOUT_MS=5000
MCP_CALL_TIMEOUT_MS=30000
MCP_MAX_RESPONSE_BYTES=1048576
MCP_ALLOW_PRIVATE_NETWORKS=true
RAG_QUEUE_MODE=bullmq
JWT_SECRET=replace-with-a-long-random-secret
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Use local for offline development only; production should use openai.
RAG_EMBEDDING_PROVIDER=openai
RAG_MIN_SCORE=0.2
RAG_VECTOR_TOP_K=30
RAG_KEYWORD_TOP_K=30
RAG_FINAL_TOP_K=5
RAG_RRF_K=60
RAG_VECTOR_TOP_K=30
RAG_KEYWORD_TOP_K=30
RAG_FINAL_TOP_K=5
RAG_RRF_K=60
RAG_JOB_STALE_MS=300000
MAX_DOCUMENT_BYTES=5242880
LOW_CODE_ASSET_MAX_BYTES=5242880
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_PUBLIC_BASE_URL=
ALIYUN_OSS_PREFIX=low-code/backgrounds
