{
  "name": "@flowmind/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "db:migrate": "ts-node -r tsconfig-paths/register src/database/migrate.ts",
    "mock:mcp": "ts-node -r tsconfig-paths/register src/dev/mock-mcp.ts",
    "mock:rag": "ts-node -r tsconfig-paths/register src/dev/mock-rag-flow.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@flowmind/shared": "workspace:*",
    "@langchain/langgraph": "^0.2.31",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "ajv": "^8.20.0",
    "bullmq": "^5.34.1",
    "ioredis": "^5.4.2",
    "langchain": "^0.3.11",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
