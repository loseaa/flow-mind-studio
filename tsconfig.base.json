{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@flowmind/shared": ["./packages/shared/src/index.ts"],
      "@flowmind/ui": ["./packages/ui/src/index.ts"]
    }
  }
}
